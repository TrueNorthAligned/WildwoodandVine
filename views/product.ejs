<section class="product-detail container">
    <div class="product-layout">
        <div class="product-gallery">
            <img src="<%= product.image %>" alt="<%= product.name %>" class="main-image">
        </div>
        <div class="product-info">
            <h1><%= product.name %></h1>
            <p class="category"><%= product.category %></p>
            <p class="description"><%= product.description %></p>
            
            <div class="features">
                <h3>Highlights:</h3>
                <ul>
                    <% product.features.forEach(feature => { %>
                        <li><%= feature %></li>
                    <% }) %>
                </ul>
            </div>

            <div class="purchase-options">
                <div class="option">
                    <input type="radio" name="format" id="digital" value="digital" checked>
                    <label for="digital">
                        <span class="option-title">Digital PDF Download</span>
                        <span class="option-price">$<%= product.price_digital.toFixed(2) %></span>
                    </label>
                </div>
                <div class="option">
                    <input type="radio" name="format" id="printed" value="printed">
                    <label for="printed">
                        <span class="option-title">Printed Copy (Ships to you)</span>
                        <span class="option-price">$<%= product.price_printed.toFixed(2) %></span>
                    </label>
                </div>
            </div>

            <button class="btn btn-primary" onclick="checkout()">Buy Now</button>
        </div>
    </div>
</section>

<script>
function checkout() {
    const format = document.querySelector('input[name="format"]:checked').value;
    if (format === 'digital') {
        window.location.href = "<%= product.stripe_digital %>";
    } else {
        window.location.href = "<%= product.stripe_printed %>";
    }
}
</script>

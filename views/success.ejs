<section class="success-message container">
    <div class="message-box">
        <span class="icon">🌿</span>
        <h1>Thank You for Your Purchase!</h1>
        <p>Your order for <strong><%= product.name %></strong> has been confirmed.</p>
        
        <div class="download-section">
            <h2>Your Digital Download</h2>
            <p>Click the button below to download your PDF planner. A copy has also been sent to your email.</p>
            <a href="/download/<%= product.pdf %>" class="btn btn-primary">Download PDF Now</a>
        </div>

        <div class="next-steps">
            <h3>What's Next?</h3>
            <ul>
                <li>Import the PDF into your favorite digital planning app (like GoodNotes or Notability).</li>
                <li>Printed copies (if ordered) will be processed within 2-3 business days.</li>
                <li>Join our community on Instagram for planning tips!</li>
            </ul>
            <a href="/shop" class="btn btn-outline">Back to Shop</a>
        </div>
    </div>
</section>

<style>
.success-message {
    padding: 80px 0;
    text-align: center;
}

.message-box {
    max-width: 600px;
    margin: 0 auto;
    background: var(--cream);
    padding: 40px;
    border-radius: 15px;
    border: 1px solid var(--sage-green);
}

.message-box .icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 20px;
}

.download-section {
    margin: 40px 0;
    padding: 30px;
    background: var(--white);
    border-radius: 10px;
}

.next-steps {
    text-align: left;
    margin-top: 40px;
}

.next-steps h3 {
    margin-bottom: 15px;
}

.next-steps ul {
    margin-bottom: 30px;
    padding-left: 20px;
}

.next-steps li {
    margin-bottom: 10px;
}
</style>
